# ─────────────────────────────────────────────
# GYDS RPC Node — Environment Configuration
# Copy to .env and fill in your values
# ─────────────────────────────────────────────

# Chain
GYDS_CHAIN_ID=13370
GYDS_NODE_MODE=rpc

# Networking
GYDS_RPC_PORT=8545
GYDS_RPC_HOST=0.0.0.0
GYDS_WS_PORT=8546
GYDS_P2P_PORT=30303

# CORS origins (comma-separated, * = allow all)
GYDS_CORS_ORIGINS=*

# Bootstrap peers (comma-separated)
# GYDS_BOOTSTRAP_NODES=tcp://BOOST_NODE_IP:30306

# Storage
GYDS_DATA_DIR=/app/data

# Logging (trace|debug|info|warn|error)
GYDS_LOG_LEVEL=info
GYDS_LOG_FORMAT=pretty
