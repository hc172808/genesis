modules = ["go-1.21", "bash"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "GOTOOLCHAIN=local GYDS_RPC_PORT=5000 GYDS_NODE_MODE=rpc GYDS_DATA_DIR=./data go run . start"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8546
externalPort = 3000

[[ports]]
localPort = 30303
externalPort = 3001

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "GYDS_RPC_PORT=5000 GYDS_NODE_MODE=rpc GYDS_DATA_DIR=/var/lib/gyds-rpcnode ./bin/gyds-rpcnode start"]
build = ["bash", "-c", "GOTOOLCHAIN=local go build -o bin/gyds-rpcnode ."]
