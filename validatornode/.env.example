# ─────────────────────────────────────────────
# GYDS Validator Node — Environment Configuration
# Copy to .env and fill in your values
# ─────────────────────────────────────────────

# Chain
GYDS_CHAIN_ID=13370
GYDS_NODE_MODE=validator

# Validator identity — set ONE of the following:
# Option 1: raw hex private key (no 0x prefix)
# GYDS_VALIDATOR_KEY=your64hexcharprivatekeyhere

# Option 2: keystore file path + password
# GYDS_KEYSTORE_PATH=/app/keystore/validator.json
# GYDS_KEYSTORE_PASSWORD=your-keystore-password

# Networking
GYDS_RPC_PORT=8545
GYDS_RPC_HOST=127.0.0.1
GYDS_P2P_PORT=30303

# Bootstrap peers (comma-separated)
# GYDS_BOOTSTRAP_NODES=tcp://BOOST_NODE_IP:30306

# Storage
GYDS_DATA_DIR=/app/data

# Logging (trace|debug|info|warn|error)
GYDS_LOG_LEVEL=info
GYDS_LOG_FORMAT=pretty
