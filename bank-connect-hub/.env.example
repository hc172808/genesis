# ─────────────────────────────────────────────────────────────────────────────
# Virtual Bank — Environment variables
#
# HOW TO USE:
#   cp .env.example .env
#   nano .env          ← fill in your real values
#   docker compose up -d
#
# MULTI-SERVER:
#   Copy this .env to every server — all pointing at the SAME Supabase
#   project. The app will share one database automatically.
#   Use deploy-multiserver.sh to push .env to all servers at once.
#
# NEVER commit .env to git (it is in .gitignore).
# ─────────────────────────────────────────────────────────────────────────────


# ── Supabase (shared across ALL servers — one database) ───────────────────────
# Find these in: Supabase Dashboard → Project Settings → API

# Your Supabase project URL
VITE_SUPABASE_URL=https://qdtsheoodhxmggiavukj.supabase.co

# Your Supabase anon/public key (safe to expose in the frontend)
VITE_SUPABASE_PUBLISHABLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InFkdHNoZW9vZGh4bWdnaWF2dWtqIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NjM1OTUzMjgsImV4cCI6MjA3OTE

# Your Supabase project ID (used by the admin app manager)
VITE_SUPABASE_PROJECT_ID=qdtsheoodhxmggiavukj


# ── Optional features ────────────────────────────────────────────────────────

# WhatsApp support number (international format, no +)
VITE_WHATSAPP_SUPPORT_NUMBER=5926421651


# ── Server / Docker settings (per-server, can differ between servers) ─────────

# Port the app will be available on this server's host
APP_PORT=3000

# Webhook port for instant redeploy from GitHub Actions
WEBHOOK_PORT=9000

# Watchtower auto-update interval (seconds)
WATCHTOWER_INTERVAL=300

# Node environment
NODE_ENV=production

# Secret used for any server-side JWT signing (change to a random 64-char string)
JWT_SECRET=change-this-to-a-random-64-character-string

# Optional: Slack/Discord webhook for Watchtower deploy notifications
# WATCHTOWER_NOTIFY_URL=https://hooks.slack.com/services/xxx/yyy/zzz


# ── Docker image source ────────────────────────────────────────────────────────
# Your GitHub username (lowercase) — used to pull the image from GHCR
GITHUB_USER=your-github-username

# Your GitHub repository name (lowercase)
GITHUB_REPO=your-repo-name


# ── setup-ubuntu.sh settings ──────────────────────────────────────────────────
# These are read by setup-ubuntu.sh on the production server.
# Run:  sudo bash setup-ubuntu.sh
#   → First run copies .env.example → .env, prompts you to fill it in.
#   → All subsequent runs are idempotent (safe to re-run).

# GitHub Personal Access Token with "read:packages" scope
# Create at: https://github.com/settings/tokens
GITHUB_PAT=ghp_REPLACE_ME

# Upstream Ethereum / BSC RPC endpoint
UPSTREAM_RPC=https://bsc-dataseed.binance.org

# Your server domain (e.g. bank.example.com), blank = use server IP
DOMAIN_NAME=

# Email for Let's Encrypt SSL certificate, blank = skip SSL
SSL_EMAIL=

# Enable ModSecurity WAF? (y or n)
ENABLE_WAF=n

# Webhook secret — leave blank to auto-generate
WEBHOOK_SECRET=

# ── Web Push Notifications (VAPID) ─────────────────────────────────────────
# Generate keys once:  node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(JSON.stringify(k,null,2))"
# Leave blank in dev — build-server auto-generates and saves to .local/vapid.json
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@yourdomain.com

# ── SMS Alerts (Twilio) ─────────────────────────────────────────────────────
# Get these from: https://console.twilio.com → Account Info
# Leave blank to disable SMS — the app works without it.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# A Twilio phone number you own (E.164 format, e.g. +12025551234)
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Email Alerts (SMTP / nodemailer) ────────────────────────────────────────
# Works with Gmail, SendGrid, Mailgun, Brevo (Sendinblue), Amazon SES, etc.
# Leave blank to disable email alerts — the app works without it.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
# For Gmail: create an App Password (Google Account → Security → App Passwords)
SMTP_PASS=your_app_password_here
# "From" address shown to recipients (defaults to SMTP_USER if blank)
SMTP_FROM=noreply@yourbank.com
SMTP_FROM_NAME=NETLIFE CASH
