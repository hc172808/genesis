# ─────────────────────────────────────────────
# GYDS Boost Node — Environment Configuration
# Copy to .env and fill in your values
# ─────────────────────────────────────────────

# Chain
GYDS_CHAIN_ID=13370
GYDS_NODE_MODE=boost

# Networking
GYDS_RPC_PORT=8545
GYDS_RPC_HOST=127.0.0.1
GYDS_P2P_PORT=30306
GYDS_BOOST_PORT=30307

# Bootstrap peers — add your fullnode/litenode addresses here
# GYDS_BOOTSTRAP_NODES=tcp://node1.gydschain.io:30303

# Storage
GYDS_DATA_DIR=/app/data

# Logging (trace|debug|info|warn|error)
GYDS_LOG_LEVEL=info
