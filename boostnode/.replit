modules = ["go-1.21"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "GYDS_RPC_PORT=5000 GYDS_RPC_HOST=0.0.0.0 GYDS_LOG_FORMAT=pretty ./bin/gyds-boostnode start"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 30303
externalPort = 3000

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "GYDS_RPC_PORT=5000 GYDS_RPC_HOST=0.0.0.0 ./bin/gyds-litenode start"]
build = ["bash", "-c", "mkdir -p bin && go build -ldflags='-s -w -X main.version=1.0.0' -o bin/gyds-litenode ."]
