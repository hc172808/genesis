# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Your deployer private key (without 0x prefix is also fine)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# GYDS RPC endpoint (your rpcnode IP or domain)
GYDS_RPC=http://YOUR_RPC_NODE_IP

# Optional: for contract verification (if you run a custom explorer)
EXPLORER_API_KEY=
